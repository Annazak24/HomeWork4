services:
  registry:
    image: registry:3.0.0
    container_name: registry
    restart: always
    hostname: registry
    ports:
      - "5005:5005"
    environment:
      - REGISTRY_HTTP_ADDR=0.0.0.0:5005
      - OTEL_TRACES_EXPORTER=none
    volumes:
      - registry_data:/var/lib/registry
    networks:
      - selenoid1

  wiremock:
    image: wiremock/wiremock:3.13.2
    container_name: wiremock
    hostname: wiremock
    volumes:
      - ./wiremock:/home/wiremock:ro
    networks:
      - selenoid1

  android:
    image: budtmo/docker-android:emulator_12.0_v3.1.1-p0
    container_name: android
    hostname: android
    depends_on:
      - wiremock
    ports:
      - "6080:6080"
      - "4723:4723"
    environment:
      - WEB_VNC=true
      - APPIUM=true
      - EMULATOR_ARGS=-no-snapshot -wipe-data -no-audio -no-boot-anim
    devices:
      - "/dev/kvm"
    networks:
      - selenoid1

  selenoid1:
    image: aerokube/selenoid:1.11.3
    hostname: selenoid1
    volumes:
      - "/var/run/docker.sock:/var/run/docker.sock"
      - "{{ selenoid_path }}/browsers.json:/etc/selenoid/browsers.json:ro"
    command: "-container-network selenoid1 -limit 10"
    networks:
      - selenoid1

  selenoid2:
    image: aerokube/selenoid:1.11.3
    hostname: selenoid2
    volumes:
      - "/var/run/docker.sock:/var/run/docker.sock"
      - "{{ selenoid_path }}/browsers.json:/etc/selenoid/browsers.json:ro"
    command: "-container-network selenoid2 -limit 10"
    networks:
      - selenoid2

  ggr:
    image: aerokube/ggr:1.7.2
    hostname: ggr
    depends_on:
      - selenoid1
      - selenoid2
    volumes:
      - "{{ selenoid_path }}/grid-router:/etc/grid-router:ro"
    command: "-guests-allowed -guests-quota test -verbose"
    networks:
      - selenoid1
      - selenoid2

  nginx:
    image: nginx
    hostname: nginx
    depends_on:
      - ggr
      - jenkins
    ports:
      - "80:80"
    volumes:
      - "{{ selenoid_path }}/selenoid.conf:/etc/nginx/conf.d/default.conf:ro"
    networks:
      - selenoid1

  jenkins:
       image: jenkins-jjb:latest
       container_name: jenkins
       user: "0:0"
       ports:
         - "8081:8080"
         - "50000:50000"
       environment:
         JENKINS_OPTS: "--prefix=/my_jenkins"
       volumes:
         - jenkins_home:/var/jenkins_home
         - /var/run/docker.sock:/var/run/docker.sock
       networks:
         - selenoid1

networks:
  selenoid1:
    name: "{{ network1 }}"
    external: true

  selenoid2:
    name: "{{ network2 }}"
    external: true

volumes:
  jenkins_home:
  registry_data: